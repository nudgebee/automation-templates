{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/nudgebee/automation-templates/schema/template.schema.json",
  "title": "Nudgebee system workflow template",
  "type": "object",
  "required": ["slug", "name", "category", "definition"],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Stable, repo-unique, immutable upsert key. Must equal the file name (without .yaml)."
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["kubernetes", "aws", "azure", "gcp", "general"]
    },
    "icon": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "INACTIVE"],
      "default": "ACTIVE"
    },
    "tags": {
      "type": "object",
      "properties": {
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Human-facing browse/search labels shown as chips in the UI (e.g. restart, scale, storage, destructive, read-only). Distinct from the event-matching fields below."
        },
        "event_sources": { "type": "array", "items": { "type": "string" } },
        "alert_names": { "type": "array", "items": { "type": "string" } },
        "subject_types": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "definition": {
      "type": "object",
      "required": ["version", "tasks"],
      "properties": {
        "version": { "type": "string" },
        "inputs": { "type": "array" },
        "triggers": { "type": "array" },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        },
        "output": { "type": "object" },
        "timeout": { "type": "string" }
      },
      "additionalProperties": true
    },
    "template_variables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "input_ref": { "type": "string" },
          "display_name": { "type": "string" },
          "help_text": { "type": "string" },
          "placeholder": { "type": "string" },
          "validation": { "type": "string" },
          "required": { "type": "boolean" },
          "group": { "type": "string" },
          "type": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  }
}
